"gradeTrustIgnored\\\": \\\"B\\\",\\n    \\\"hasWarnings\\\": false,\\n    \\\"isExceptional\\\": false,\\n    \\\"progress\\\": 100,\\n    \\\"duration\\\": 119930,\\n    \\\"delegation\\\": 1\\n  },\\n  {\\n    \\\"ipAddress\\\": \\\"74.125.21.101\\\",\\n    \\\"serverName\\\": \\\"yv-in-f101.1e100.net\\\",\\n    \\\"statusMessage\\\": \\\"Ready\\\",\\n    \\\"grade\\\": \\\"B\\\",\\n    \\\"gradeTrustIgnored\\\": \\\"B\\\",\\n    \\\"hasWarnings\\\": false,\\n    \\\"isExceptional\\\": false,\\n    \\\"progress\\\": 100,\\n    \\\"duration\\\": 120751,\\n    \\\"delegation\\\": 1\\n  },\\n  {\\n    \\\"ipAddress\\\": \\\"2607:f8b0:4002:c06:0:0:0:8b\\\",\\n    \\\"serverName\\\": \\\"yv-in-f139.1e100.net\\\",\\n    \\\"statusMessage\\\": \\\"Ready\\\",\\n    \\\"grade\\\": \\\"B\\\",\\n    \\\"gradeTrustIgnored\\\": \\\"B\\\",\\n    \\\"hasWarnings\\\": false,\\n    \\\"isExceptional\\\": false,\\n    \\\"progress\\\": 100,\\n    \\\"duration\\\": 122864,\\n    \\\"delegation\\\": 1\\n  },\\n  {\\n    \\\"ipAddress\\\": \\\"74.125.21.100\\\",\\n    \\\"serverName\\\": \\\"yv-in-f100.1e100.net\\\",\\n    \\\"statusMessage\\\": \\\"Ready\\\",\\n    \\\"grade\\\": \\\"B\\\",\\n    \\\"gradeTrustIgnored\\\": \\\"B\\\",\\n    \\\"hasWarnings\\\": false,\\n    \\\"isExceptional\\\": false,\\n    \\\"progress\\\": 100,\\n    \\\"duration\\\": 119044,\\n    \\\"delegation\\\": 1\\n  },\\n  {\\n    \\\"ipAddress\\\": \\\"2607:f8b0:4002:c06:0:0:0:8a\\\",\\n    \\\"serverName\\\": \\\"yv-in-x8a.1e100.net\\\",\\n    \\\"statusMessage\\\": \\\"Ready\\\",\\n    \\\"grade\\\": \\\"B\\\",\\n    \\\"gradeTrustIgnored\\\": \\\"B\\\",\\n    \\\"hasWarnings\\\": false,\\n    \\\"isExceptional\\\": false,\\n    \\\"progress\\\": 100,\\n    \\\"duration\\\": 122866,\\n    \\\"delegation\\\": 1\\n  },\\n  {\\n    \\\"ipAddress\\\": \\\"74.125.21.102\\\",\\n    \\\"serverName\\\": \\\"yv-in-f102.1e100.net\\\",\\n    \\\"statusMessage\\\": \\\"Ready\\\",\\n    \\\"grade\\\": \\\"B\\\",\\n    \\\"gradeTrustIgnored\\\": \\\"B\\\",\\n    \\\"hasWarnings\\\": false,\\n    \\\"isExceptional\\\": false,\\n    \\\"progress\\\": 100,\\n    \\\"duration\\\": 119878,\\n    \\\"delegation\\\": 1\\n  },\\n  {\\n    \\\"ipAddress\\\": \\\"74.125.21.113\\\",\\n    \\\"serverName\\\": \\\"yv-in-f113.1e100.net\\\",\\n    \\\"statusMessage\\\": \\\"Ready\\\",\\n    \\\"grade\\\": \\\"B\\\",\\n    \\\"gradeTrustIgnored\\\": \\\"B\\\",\\n    \\\"hasWarnings\\\": false,\\n    \\\"isExceptional\\\": false,\\n    \\\"progress\\\": 100,\\n    \\\"duration\\\": 119356,\\n    \\\"delegation\\\": 1\\n  },\\n  {\\n    \\\"ipAddress\\\": \\\"2607:f8b0:4002:c06:0:0:0:71\\\",\\n    \\\"serverName\\\": \\\"yv-in-x71.1e100.net\\\",\\n    \\\"statusMessage\\\": \\\"Ready\\\",\\n    \\\"grade\\\": \\\"B\\\",\\n    \\\"gradeTrustIgnored\\\": \\\"B\\\",\\n    \\\"hasWarnings\\\": false,\\n    \\\"isExceptional\\\": false,\\n    \\\"progress\\\": 100,\\n    \\\"duration\\\": 122348,\\n    \\\"delegation\\\": 1\\n  }\\n]\\n\\nSecurity Headers:\\n\\nHSTS:\\nAusente\\n\\nContent-Security-Policy:\\nAusente\\n\\nX-Frame-Options:\\nAusente\\n\\nX-Content-Type-Options:\\nAusente\\n\\nReferrer-Policy:\\nAusente\\n\\nDados técnicos SSL/TLS disponíveis:\\nProtocolos:\\n[\\n  {\\n    \\\"id\\\": 769,\\n    \\\"name\\\": \\\"TLS\\\",\\n    \\\"version\\\": \\\"1.0\\\"\\n  },\\n  {\\n    \\\"id\\\": 770,\\n    \\\"name\\\": \\\"TLS\\\",\\n    \\\"version\\\": \\\"1.1\\\"\\n  },\\n  {\\n    \\\"id\\\": 771,\\n    \\\"name\\\": \\\"TLS\\\",\\n    \\\"version\\\": \\\"1.2\\\"\\n  },\\n  {\\n    \\\"id\\\": 772,\\n    \\\"name\\\": \\\"TLS\\\",\\n    \\\"version\\\": \\\"1.3\\\"\\n  }\\n]\\n\\nCipher Suites:\\n[\\n  {\\n    \\\"protocol\\\": 769,\\n    \\\"list\\\": [\\n      {\\n        \\\"id\\\": 49161,\\n        \\\"name\\\": \\\"TLS_ECDHE_ECDSA_WITH_AES_128_CBC_SHA\\\",\\n        \\\"cipherStrength\\\": 128,\\n        \\\"kxType\\\": \\\"ECDH\\\",\\n        \\\"kxStrength\\\": 3072,\\n        \\\"namedGroupBits\\\": 256,\\n        \\\"namedGroupId\\\": 29,\\n        \\\"namedGroupName\\\": \\\"x25519\\\",\\n        \\\"q\\\": 1\\n      },\\n      {\\n        \\\"id\\\": 49162,\\n        \\\"name\\\": \\\"TLS_ECDHE_ECDSA_WITH_AES_256_CBC_SHA\\\",\\n        \\\"cipherStrength\\\": 256,\\n        \\\"kxType\\\": \\\"ECDH\\\",\\n        \\\"kxStrength\\\": 3072,\\n        \\\"namedGroupBits\\\": 256,\\n        \\\"namedGroupId\\\": 29,\\n        \\\"namedGroupName\\\": \\\"x25519\\\",\\n        \\\"q\\\": 1\\n      },\\n      {\\n        \\\"id\\\": 49171,\\n        \\\"name\\\": \\\"TLS_ECDHE_RSA_WITH_AES_128_CBC_SHA\\\",\\n        \\\"cipherStrength\\\": 128,\\n        \\\"kxType\\\": \\\"ECDH\\\",\\n        \\\"kxStrength\\\": 3072,\\n        \\\"namedGroupBits\\\": 256,\\n        \\\"namedGroupId\\\": 29,\\n        \\\"namedGroupName\\\": \\\"x25519\\\",\\n        \\\"q\\\": 1\\n      },\\n      {\\n        \\\"id\\\": 49172,\\n        \\\"name\\\": \\\"TLS_ECDHE_RSA_WITH_AES_256_CBC_SHA\\\",\\n        \\\"cipherStrength\\\": 256,\\n        \\\"kxType\\\": \\\"ECDH\\\",\\n        \\\"kxStrength\\\": 3072,\\n        \\\"namedGroupBits\\\": 256,\\n        \\\"namedGroupId\\\": 29,\\n        \\\"namedGroupName\\\": \\\"x25519\\\",\\n        \\\"q\\\": 1\\n      },\\n      {\\n        \\\"id\\\": 47,\\n        \\\"name\\\": \\\"TLS_RSA_WITH_AES_128_CBC_SHA\\\",\\n        \\\"cipherStrength\\\": 128,\\n        \\\"q\\\": 1\\n      },\\n      {\\n        \\\"id\\\": 53,\\n        \\\"name\\\": \\\"TLS_RSA_WITH_AES_256_CBC_SHA\\\",\\n        \\\"cipherStrength\\\": 256,\\n        \\\"q\\\": 1\\n      },\\n      {\\n        \\\"id\\\": 10,\\n        \\\"name\\\": \\\"TLS_RSA_WITH_3DES_EDE_CBC_SHA\\\",\\n        \\\"cipherStrength\\\": 112,\\n        \\\"q\\\": 1\\n      }\\n    ],\\n    \\\"preference\\\": true\\n  },\\n  {\\n    \\\"protocol\\\": 770,\\n    \\\"list\\\": [\\n      {\\n        \\\"id\\\": 49161,\\n        \\\"name\\\": \\\"TLS_ECDHE_ECDSA_WITH_AES_1